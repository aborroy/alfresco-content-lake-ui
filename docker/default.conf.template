server {
    listen 8080;
    server_name localhost;

    # Serve the ACA static files
    location / {
        root   /usr/share/nginx/html;
        index  index.html index.htm;
        try_files $uri $uri/ /index.html;
    }

    # Proxy Alfresco Repository requests
    location /alfresco/ {
        proxy_pass ${APP_CONFIG_ECM_HOST}/alfresco/;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # Proxy RAG Service requests
    location /api/rag/ {
        proxy_pass ${APP_CONFIG_RAG_URL}/api/rag/;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_hide_header WWW-Authenticate;
    }

    # Serve app.config.json (processed at startup by entrypoint script)
    location /app.config.json {
        alias /usr/share/nginx/html/app.config.json;
        add_header Cache-Control "no-cache";
    }

    error_page 500 502 503 504 /50x.html;
    location = /50x.html {
        root /usr/share/nginx/html;
    }
}

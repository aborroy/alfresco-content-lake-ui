{
  "$id": "ext-rag",
  "$version": "1.0.0",
  "$name": "RAG Assistant",
  "$vendor": "Alfresco Community",
  "$license": "Apache-2.0",

  "actions": [
    { "id": "ext-rag.open-chat", "type": "RAG_OPEN_CHAT" },
    { "id": "ext-rag.ask-about", "type": "RAG_ASK_ABOUT", "payload": "$(context.selection.first.entry)" },
    { "id": "ext-rag.scope.enable-folder", "type": "CONTENT_LAKE_ENABLE_FOLDER_SCOPE", "payload": "$(context.selection.first.entry)" },
    { "id": "ext-rag.scope.disable-folder", "type": "CONTENT_LAKE_DISABLE_FOLDER_SCOPE", "payload": "$(context.selection.first.entry)" }
  ],

  "routes": [
    {
      "id": "ext-rag.page",
      "path": "rag",
      "component": "ext-rag.page",
      "auth": ["content-services.auth"],
      "data": { "title": "RAG Assistant" }
    }
  ],

  "features": {
    "navbar": [
      {
        "id": "app.navbar.primary",
        "items": [
          {
            "id": "ext-rag.nav",
            "icon": "psychology",
            "title": "RAG Assistant",
            "description": "AI-powered semantic search and Q&A",
            "route": "rag",
            "order": 500
          }
        ]
      }
    ],

    "toolbar": [
      {
        "id": "app.toolbar.more",
        "children": [
          {
            "id": "ext-rag.toolbar.ask-about",
            "order": 91,
            "icon": "psychology",
            "title": "Ask AI about this document",
            "actions": { "click": "ext-rag.ask-about" },
            "rules": { "visible": ["app.selection.file"] }
          },
          {
            "id": "ext-rag.toolbar.ask-about-folder",
            "order": 92,
            "icon": "psychology",
            "title": "Ask AI about this folder",
            "actions": { "click": "ext-rag.ask-about" },
            "rules": { "visible": ["app.selection.folder"] }
          }
        ]
      }
    ],

    "contextMenu": [
      {
        "id": "ext-rag.context.enable-folder-scope",
        "order": 92,
        "icon": "offline_bolt",
        "title": "Enable Content Lake for this folder",
        "actions": { "click": "ext-rag.scope.enable-folder" },
        "rules": { "visible": ["app.selection.folder", "app.selection.folder.canUpdate", "!ext-rag.selection.folder.indexed"] }
      },
      {
        "id": "ext-rag.context.disable-folder-scope",
        "order": 93,
        "icon": "hide_source",
        "title": "Disable Content Lake for this folder",
        "actions": { "click": "ext-rag.scope.disable-folder" },
        "rules": { "visible": ["app.selection.folder", "app.selection.folder.canUpdate", "ext-rag.selection.folder.indexed"] }
      },
      {
        "id": "ext-rag.context.ask-about",
        "order": 94,
        "icon": "psychology",
        "title": "Ask AI about this document",
        "actions": { "click": "ext-rag.ask-about" },
        "rules": { "visible": ["app.selection.file"] }
      },
      {
        "id": "ext-rag.context.ask-about-folder",
        "order": 95,
        "icon": "psychology",
        "title": "Ask AI about this folder",
        "actions": { "click": "ext-rag.ask-about" },
        "rules": { "visible": ["app.selection.folder"] }
      }
    ],

    "viewer": {
      "toolbarActions": [
        {
          "id": "app.viewer.toolbar.more",
          "children": [
            {
              "id": "ext-rag.viewer.ask-about",
              "order": 10,
              "icon": "psychology",
              "title": "Ask AI about this document",
              "actions": { "click": "ext-rag.ask-about" }
            }
          ]
        }
      ]
    },

    "sidebar": {
      "tabs": [
        {
          "id": "ext-rag.sidebar-tab",
          "order": 200,
          "title": "Ask AI",
          "icon": "psychology",
          "component": "ext-rag.sidebar"
        },
        {
          "id": "ext-rag.content-lake-sidebar-tab",
          "order": 210,
          "title": "Content Lake",
          "icon": "offline_bolt",
          "component": "ext-rag.content-lake-sidebar"
        }
      ]
    },

    "badges": [
      {
        "id": "ext-rag.badge.content-lake-sync-status",
        "icon": "help_outline",
        "tooltip": "Content Lake ingestion status",
        "component": "ext-rag.content-lake-status-badge",
        "rules": {
          "visible": ["ext-rag.node.in-content-lake"]
        }
      },
      {
        "id": "ext-rag.badge.content-lake-enabled",
        "icon": "offline_bolt",
        "tooltip": "Content Lake enabled",
        "rules": {
          "visible": "ext-rag.node.in-content-lake"
        }
      },
      {
        "id": "ext-rag.badge.content-lake-excluded",
        "icon": "block",
        "tooltip": "Excluded from Content Lake",
        "rules": {
          "visible": "ext-rag.node.excluded-from-content-lake"
        }
      }
    ]
  }
}
